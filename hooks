import React from 'react';
import { useResume } from '../../context/ResumeContext';
import { generatePDF } from '../../utils/pdfGenerator';

const PDFExport = ({ templateId }) => {
  const { state } = useResume();
  const [isGenerating, setIsGenerating] = React.useState(false);
  const [downloadStatus, setDownloadStatus] = React.useState('');

  const handleDownloadPDF = async () => {
    setIsGenerating(true);
    setDownloadStatus('Generating ultra-high quality 8K PDF...');
    
    try {
      await generatePDF(state, templateId);
      setDownloadStatus('PDF downloaded successfully!');
      setTimeout(() => setDownloadStatus(''), 3000);
    } catch (error) {
      console.error('Error generating PDF:', error);
      setDownloadStatus('Error generating PDF. Please try again.');
      setTimeout(() => setDownloadStatus(''), 3000);
    } finally {
      setIsGenerating(false);
    }
  };

  return (
    <div className="pdf-export" style={{
      padding: '24px',
      background: 'white',
      borderRadius: '12px',
      boxShadow: '0 2px 8px rgba(0,0,0,0.05)',
      border: '1px solid #e9ecef',
      maxWidth: '400px',
      margin: '0 auto'
    }}>
      <h3 style={{
        margin: '0 0 8px 0',
        fontSize: '20px',
        color: '#1a1a1a',
        fontWeight: '600'
      }}>
        Download Your Resume
      </h3>
      
      <p style={{
        margin: '0 0 20px 0',
        color: '#666',
        fontSize: '14px',
        lineHeight: '1.5'
      }}>
        Click the button below to download your resume as a high-quality 8K PDF
      </p>
      
      <button 
        onClick={handleDownloadPDF}
        disabled={isGenerating}
        style={{
          width: '100%',
          padding: '14px 24px',
          background: isGenerating ? '#ccc' : 'linear-gradient(135deg, #0070f3 0%, #0060d6 100%)',
          color: 'white',
          border: 'none',
          borderRadius: '8px',
          fontSize: '16px',
          fontWeight: '600',
          cursor: isGenerating ? 'not-allowed' : 'pointer',
          transition: 'all 0.2s ease',
          boxShadow: isGenerating ? 'none' : '0 4px 6px rgba(0,112,243,0.2)',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          gap: '8px'
        }}
        onMouseEnter={(e) => {
          if (!isGenerating) {
            e.target.style.background = 'linear-gradient(135deg, #0060d6 0%, #0050c0 100%)';
            e.target.style.transform = 'translateY(-2px)';
            e.target.style.boxShadow = '0 6px 12px rgba(0,112,243,0.3)';
          }
        }}
        onMouseLeave={(e) => {
          if (!isGenerating) {
            e.target.style.background = 'linear-gradient(135deg, #0070f3 0%, #0060d6 100%)';
            e.target.style.transform = 'translateY(0)';
            e.target.style.boxShadow = '0 4px 6px rgba(0,112,243,0.2)';
          }
        }}
      >
        {isGenerating ? (
          <>
            <span style={{ fontSize: '18px' }}>⏳</span>
            Generating 8K PDF...
          </>
        ) : (
          <>
            <span style={{ fontSize: '18px' }}>📥</span>
            Download 8K PDF
          </>
        )}
      </button>
      
      {downloadStatus && (
        <div style={{
          marginTop: '16px',
          padding: '12px 16px',
          borderRadius: '6px',
          fontSize: '14px',
          background: downloadStatus.includes('Error') ? '#fff5f5' : 
                     downloadStatus.includes('success') ? '#f0fff4' : '#fff9e6',
          color: downloadStatus.includes('Error') ? '#c53030' : 
                 downloadStatus.includes('success') ? '#276749' : '#975a16',
          border: `1px solid ${
            downloadStatus.includes('Error') ? '#fc8181' : 
            downloadStatus.includes('success') ? '#9ae6b4' : '#fbd38d'
          }`,
          textAlign: 'center'
        }}>
          {downloadStatus}
        </div>
      )}

      <div style={{
        marginTop: '24px',
        padding: '16px',
        background: '#f8f9fa',
        borderRadius: '8px',
        border: '1px solid #e9ecef'
      }}>
        <h4 style={{
          margin: '0 0 12px 0',
          fontSize: '16px',
          color: '#1a1a1a',
          fontWeight: '600'
        }}>
          Tips for best PDF results:
        </h4>
        <ul style={{
          margin: '0',
          padding: '0 0 0 20px',
          color: '#666',
          fontSize: '14px',
          lineHeight: '1.6'
        }}>
          <li>✓ Ultra-high quality 8K resolution (7680x4320)</li>
          <li>✓ 600 DPI professional print quality</li>
          <li>✓ Lossless compression for maximum clarity</li>
          <li>✓ Preserves all fonts, colors, and styling</li>
          <li>✓ Perfect for both digital and print use</li>
        </ul>
      </div>
    </div>
  );
};

export default PDFExport;